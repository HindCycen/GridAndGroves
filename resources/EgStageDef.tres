[sub_resource type="Resource" id="SubResource_rand"]
resource_local_to_scene = false
script = ExtResource("3")
PossibleEvents = Array[Object]([SubResource("SubResource_evt1"), SubResource("SubResource_evt2"), SubResource("SubResource_evt3")])
metadata/_custom_type_script = "res://resources/EventRand.cs"

[resource]
script = ExtResource("1")
StageEnemyChart = ExtResource("2")
StageEventRand = SubResource("SubResource_rand")
