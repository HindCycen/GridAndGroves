[sub_resource type="Resource" id="SubResource_evt2"]
resource_local_to_scene = false
script = ExtResource("4")
EventDesc = "A locked chest sits in the corner."
Choices = Array[Object]([SubResource("SubResource_choice3"), SubResource("SubResource_choice4")])
