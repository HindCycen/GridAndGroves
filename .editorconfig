root = true

[*]
charset = utf-8

[*.cs]

# 使用 K&R 风格大括号
csharp_new_line_before_open_brace = none

# 缩进
indent_style = space
indent_size = 4

# if / for 等始终带大括号（强烈推荐）
csharp_prefer_braces = true:warning
csharp_space_after_cast = true

[EmptyWithNamespace.cs] # 匹配所有以 Template.cs 结尾的文件
generated_code = true